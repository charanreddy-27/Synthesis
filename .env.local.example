# --- LLM provider --------------------------------------------------------
# "google" uses the Gemini API; "mock" streams a canned answer offline.
# If GOOGLE_API_KEY is empty, Synthesis falls back to mock automatically.
LLM_PROVIDER=google
GOOGLE_API_KEY=
# Fast/cheap model for researchers; strong model for synthesizer/critic.
GOOGLE_MODEL=gemini-2.5-flash
GOOGLE_MODEL_SYNTHESIZER=gemini-2.5-pro
# Embedding model (768-dim). Used by the researcher's retrieval step.
GOOGLE_EMBED_MODEL=text-embedding-004

# --- Search --------------------------------------------------------------
# Set this to use a real SearXNG instance (see docker-compose.yml).
# Leave empty to use the offline mock fixtures.
SEARXNG_URL=
# Force the mock even if SEARXNG_URL is set: SEARCH_PROVIDER=mock
SEARCH_PROVIDER=

# --- Vector store --------------------------------------------------------
# Set this to use pgvector (see docker-compose.yml). Empty = in-memory store.
DATABASE_URL=

# --- Run guardrails (wired in later phases) ------------------------------
MAX_TOKENS_PER_RUN=120000
